{
  "name": "letterpress-markdown",
  "displayName": "Letterpress Markdown",
  "description": "A nicer, opinionated Markdown Preview experience with centered prose, collapsible headings, table of contents, etc.",
  "version": "0.11.2",
  "publisher": "rsomani95",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "markdown",
    "preview",
    "typography",
    "word-count",
    "fold",
    "table-of-contents"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rsomani95/letterpress-markdown.git"
  },
  "homepage": "https://github.com/rsomani95/letterpress-markdown#readme",
  "bugs": {
    "url": "https://github.com/rsomani95/letterpress-markdown/issues"
  },
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "extensionKind": [
    "workspace"
  ],
  "extensionPack": [
    "bierner.markdown-checkbox"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:skill"
  ],
  "contributes": {
    "markdown.previewStyles": [
      "./styles/fonts.css",
      "./styles/preview.css"
    ],
    "markdown.previewScripts": [
      "./scripts/fold.js",
      "./scripts/width-slider.js",
      "./scripts/color-swatches.js",
      "./scripts/toc.js"
    ],
    "configurationDefaults": {}
  },
  "scripts": {
    "build": "tsc -p .",
    "vscode:prepublish": "npm run build",
    "package": "mkdir -p dist-vsix && vsce package --out dist-vsix/",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^6.0.2"
  }
}
